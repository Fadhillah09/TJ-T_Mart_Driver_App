<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 1. Nama Pembeli (paling atas, bold) -->
        <TextView
            android:id="@+id/tvNamaPembeli"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Pelanggan"
            android:textStyle="bold"
            android:textColor="#000000"
            android:textSize="16sp" />

        <!-- 2. Alamat Gedung & Kamar -->
        <TextView
            android:id="@+id/tvAlamat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alamat"
            android:textColor="#757575"
            android:textSize="13sp"
            android:layout_marginTop="2dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- 3. Nama Mart (tidak bold, di bawah alamat) -->
        <TextView
            android:id="@+id/tvIdPesanan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="TJ Mart Putra"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginTop="2dp" />

        <!-- 4. Harga -->
        <TextView
            android:id="@+id/tvTotalHarga"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 0"
            android:textColor="#4CAF50"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="6dp" />

        <!-- 5. Metode Pembayaran -->
        <TextView
            android:id="@+id/tvMetodePembayaran"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Metode Pembayaran"
            android:textColor="#1976D2"
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:textStyle="italic" />

        <!-- 6. Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Diproses"
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:textColor="#888888" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTolak"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:minHeight="0dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="TOLAK"
                android:textColor="#E53935"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnTerima"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:minHeight="0dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="TERIMA"
                android:textSize="12sp"
                android:backgroundTint="#A8000E" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>