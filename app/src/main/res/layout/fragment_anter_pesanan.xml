<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════════════════════════════
             HEADER
        ══════════════════════════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1565C0"
            android:padding="16dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="@android:color/white"
                android:padding="8dp"
                android:layout_gravity="start|center_vertical" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sedang Diantar"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_gravity="center_horizontal" />

                <TextView
                    android:id="@+id/tvIdPesanan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#INV-001"
                    android:textColor="#B3E5FC"
                    android:textSize="13sp"
                    android:layout_gravity="center_horizontal" />
            </LinearLayout>
        </FrameLayout>

        <!-- ══════════════════════════════════════
             TIMELINE STATUS
        ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@android:color/white"
            android:paddingVertical="12dp"
            android:paddingHorizontal="8dp"
            android:gravity="center_vertical"
            android:elevation="4dp">

            <!-- Step 1: Diproses -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:alpha="0.4" android:id="@+id/layoutStep1">
                <ImageView android:id="@+id/ivStep1"
                    android:layout_width="28dp" android:layout_height="28dp"
                    android:src="@drawable/ic_receipt" android:tint="#1565C0"/>
                <TextView android:id="@+id/tvStep1"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Diproses" android:textSize="10sp" android:textColor="#1565C0"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Garis -->
            <View android:layout_width="16dp" android:layout_height="2dp" android:background="#1565C0" android:alpha="0.3"/>

            <!-- Step 2: Disiapkan -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:alpha="0.4" android:id="@+id/layoutStep2">
                <ImageView android:id="@+id/ivStep2"
                    android:layout_width="28dp" android:layout_height="28dp"
                    android:src="@drawable/ic_shopping_bag" android:tint="#1565C0"/>
                <TextView android:id="@+id/tvStep2"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Disiapkan" android:textSize="10sp" android:textColor="#1565C0"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Garis -->
            <View android:layout_width="16dp" android:layout_height="2dp" android:background="#1565C0"/>

            <!-- Step 3: Diantar (AKTIF) -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:id="@+id/layoutStep3">
                <ImageView android:id="@+id/ivStep3"
                    android:layout_width="28dp" android:layout_height="28dp"
                    android:src="@drawable/ic_delivery" android:tint="#1565C0"/>
                <TextView android:id="@+id/tvStep3"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Diantar" android:textSize="10sp" android:textColor="#1565C0"
                    android:textStyle="bold" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Garis -->
            <View android:layout_width="16dp" android:layout_height="2dp" android:background="#1565C0" android:alpha="0.3"/>

            <!-- Step 4: Tiba -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center"
                android:alpha="0.4" android:id="@+id/layoutStep4">
                <ImageView android:id="@+id/ivStep4"
                    android:layout_width="28dp" android:layout_height="28dp"
                    android:src="@drawable/ic_check_circle" android:tint="#4CAF50"/>
                <TextView android:id="@+id/tvStep4"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tiba" android:textSize="10sp" android:textColor="#4CAF50"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════════════════════════════
             MAP TRACKING
        ══════════════════════════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp">

            <WebView
                android:id="@+id/webViewTracking"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Loading overlay -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="visible"
                android:indeterminateTint="#1565C0" />

            <!-- Jarak chip -->
            <TextView
                android:id="@+id/tvJarak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="#CC1565C0"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Menghitung jarak..."
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Timer -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="12dp"
                android:background="#CC000000"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:elevation="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱ "
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </FrameLayout>

        <!-- ══════════════════════════════════════
             INFO PEMBELI
        ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Informasi Pembeli"
                    android:textSize="13sp"
                    android:textColor="#9E9E9E"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp" />

                <!-- Nama -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_person" android:tint="#1565C0"
                        android:layout_marginEnd="10dp"/>
                    <TextView android:id="@+id/tvNamaPembeli"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Nama Pembeli" android:textSize="15sp"
                        android:textColor="#212121" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Telepon -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_phone" android:tint="#1565C0"
                        android:layout_marginEnd="10dp"/>
                    <TextView android:id="@+id/tvTeleponPembeli"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="-" android:textSize="14sp" android:textColor="#424242"/>
                </LinearLayout>

                <!-- Alamat -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="top">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_location_pin" android:tint="#E53935"
                        android:layout_marginEnd="10dp"/>
                    <TextView android:id="@+id/tvAlamatTujuan"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Alamat tujuan" android:textSize="14sp"
                        android:textColor="#424242"/>
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F0F0F0" android:layout_marginVertical="12dp"/>

                <!-- Metode & Total -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Metode Bayar" android:textSize="11sp" android:textColor="#9E9E9E"/>
                        <TextView android:id="@+id/tvMetodePembayaran"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Cash" android:textSize="14sp" android:textColor="#212121"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="end">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total" android:textSize="11sp" android:textColor="#9E9E9E"/>
                        <TextView android:id="@+id/tvTotalHarga"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Rp 0" android:textSize="16sp" android:textColor="#1565C0"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════
             TOMBOL AKSI (2 kolom)
        ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingBottom="8dp">

            <!-- Hubungi Pembeli -->
            <Button
                android:id="@+id/btnHubungiPembeli"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="📞 Hubungi"
                android:textSize="14sp"
                android:backgroundTint="#F5F5F5"
                android:textColor="#1565C0"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#1565C0"
                app:strokeWidth="2dp" />

            <!-- Navigasi -->
            <Button
                android:id="@+id/btnNavigasi"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="🗺️ Navigasi"
                android:textSize="14sp"
                android:backgroundTint="#1565C0"
                android:textColor="@android:color/white"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <!-- ══════════════════════════════════════
             TOMBOL PESANAN TIBA (full width)
        ══════════════════════════════════════ -->
        <Button
            android:id="@+id/btnPesananTiba"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="24dp"
            android:text="✅ Pesanan Tiba"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="#2E7D32"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>