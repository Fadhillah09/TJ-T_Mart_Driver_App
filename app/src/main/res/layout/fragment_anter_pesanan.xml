<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/telkom_red"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:tint="@color/white"
            android:padding="2dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Sedang Diantar"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvIdPesanan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFCDD2"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="32dp"
            android:layout_height="32dp" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         TIMELINE STATUS — 4 Step
    ═══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:paddingVertical="10dp"
        android:paddingHorizontal="8dp"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <!-- Step 1: Diproses -->
        <LinearLayout
            android:id="@+id/layoutStep1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:alpha="0.4">
            <ImageView
                android:id="@+id/ivStep1"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_receipt"
                android:tint="@color/telkom_red" />
            <TextView
                android:id="@+id/tvStep1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diproses"
                android:textSize="9sp"
                android:textColor="@color/telkom_red"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <View android:layout_width="14dp" android:layout_height="2dp"
            android:background="@color/telkom_red" android:alpha="0.3" />

        <!-- Step 2: Disiapkan -->
        <LinearLayout
            android:id="@+id/layoutStep2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:alpha="0.4">
            <ImageView
                android:id="@+id/ivStep2"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_shopping_bag"
                android:tint="@color/telkom_red" />
            <TextView
                android:id="@+id/tvStep2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disiapkan"
                android:textSize="9sp"
                android:textColor="@color/telkom_red"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <View android:layout_width="14dp" android:layout_height="2dp"
            android:background="@color/telkom_red" />

        <!-- Step 3: Diantar (AKTIF) -->
        <LinearLayout
            android:id="@+id/layoutStep3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:id="@+id/ivStep3"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_delivery"
                android:tint="@color/telkom_red" />
            <TextView
                android:id="@+id/tvStep3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diantar"
                android:textSize="9sp"
                android:textColor="@color/telkom_red"
                android:textStyle="bold"
                android:layout_marginTop="3dp" />
        </LinearLayout>

        <View android:layout_width="14dp" android:layout_height="2dp"
            android:background="@color/telkom_red" android:alpha="0.3" />

        <!-- Step 4: Tiba -->
        <LinearLayout
            android:id="@+id/layoutStep4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:alpha="0.4">
            <ImageView
                android:id="@+id/ivStep4"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_check_circle"
                android:tint="#4CAF50" />
            <TextView
                android:id="@+id/tvStep4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiba"
                android:textSize="9sp"
                android:textColor="#4CAF50"
                android:layout_marginTop="3dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         SCROLLABLE CONTENT
    ═══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- MAP TRACKING -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="260dp">

                <WebView
                    android:id="@+id/webViewTracking"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="visible"
                    android:indeterminateTint="@color/telkom_red" />

                <!-- Chip Jarak — kanan atas -->
                <TextView
                    android:id="@+id/tvJarak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="10dp"
                    android:background="#CCB00000"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:text="Menghitung jarak..."
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <!-- Timer — kiri atas -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="10dp"
                    android:background="#CC000000"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ "
                        android:textColor="@color/white"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textColor="#FFD700"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Banner hampir tiba (muncul otomatis saat jarak ≤ 5m) -->
                <LinearLayout
                    android:id="@+id/bannerDekat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="#EEB00000"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📍 Hampir tiba! Pesan otomatis telah terkirim ke pelanggan."
                        android:textColor="@color/white"
                        android:textSize="12sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- ══════════════════════════════════════
                 CARD: INFORMASI PEMBELI
            ══════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INFORMASI PEMBELI"
                        android:textSize="11sp"
                        android:textColor="#9E9E9E"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="12dp" />

                    <!-- Nama -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_person"
                            android:tint="@color/telkom_red"
                            android:layout_marginEnd="10dp" />
                        <TextView
                            android:id="@+id/tvNamaPembeli"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nama Pembeli"
                            android:textSize="15sp"
                            android:textColor="#212121"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Telepon -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_phone"
                            android:tint="@color/telkom_red"
                            android:layout_marginEnd="10dp" />
                        <TextView
                            android:id="@+id/tvTeleponPembeli"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="14sp"
                            android:textColor="#424242" />
                    </LinearLayout>

                    <!-- Alamat -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_location_pin"
                            android:tint="@color/telkom_red"
                            android:layout_marginEnd="10dp" />
                        <TextView
                            android:id="@+id/tvAlamatTujuan"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Alamat tujuan"
                            android:textSize="14sp"
                            android:textColor="#424242" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginVertical="12dp" />

                    <!-- Metode Bayar & Total -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Metode Bayar"
                                android:textSize="11sp"
                                android:textColor="#9E9E9E" />
                            <TextView
                                android:id="@+id/tvMetodePembayaran"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cash"
                                android:textSize="14sp"
                                android:textColor="#212121"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="end">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total"
                                android:textSize="11sp"
                                android:textColor="#9E9E9E" />
                            <TextView
                                android:id="@+id/tvTotalHarga"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp 0"
                                android:textSize="16sp"
                                android:textColor="@color/green"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══════════════════════════════════════
                 TOMBOL AKSI 2 KOLOM
                 Kiri : 📞 Hubungi  → WhatsApp / fallback dial
                 Kanan: 💬 Chat     → ChatPesananFragment
            ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHubungiPembeli"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="📞 Hubungi"
                    android:textSize="13sp"
                    android:textColor="@color/telkom_red"
                    app:strokeColor="@color/telkom_red"
                    app:strokeWidth="1.5dp"
                    app:backgroundTint="@color/white"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChat"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="💬 Chat"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/telkom_red"
                    style="@style/Widget.MaterialComponents.Button" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="12dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPesananTiba"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="20dp"
        android:text="✓ Pesanan Tiba"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:backgroundTint="@color/telkom_red"
        style="@style/Widget.MaterialComponents.Button" />

</LinearLayout>