<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_riwayat"
    android:elevation="2dp">

    <!-- Header: Origin → Destination + Waktu + Badge Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <!-- Icon toko -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_store"
            android:background="@drawable/bg_icon_store"
            android:padding="6dp"
            android:scaleType="centerInside" />

        <!-- Rute -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvOrigin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TJ Mart Putri"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_main"
                    android:maxLines="1" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/arrow_down_float"
                    android:rotation="-90"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:alpha="0.5" />

                <TextView
                    android:id="@+id/tvDestination"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Asrama Putra Gedung A"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_main"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvWaktu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10.30 WIB"
                android:textSize="11sp"
                android:textColor="@color/text_sub"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Badge Status -->
        <TextView
            android:id="@+id/tvStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selesai"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp" />

    <!-- Info User -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/ivAvatarUser"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_default_avatar"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_avatar_circle" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tvNamaPelanggan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User name"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_main" />

            <TextView
                android:id="@+id/tvJumlahPesanan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total : 3 Pesanan"
                android:textSize="11sp"
                android:textColor="@color/text_sub"
                android:layout_marginTop="1dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp" />

    <!-- Section: Item Pesanan -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Item pesanan"
        android:textSize="12sp"
        android:textColor="@color/text_sub"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp" />

    <!-- RecyclerView Items (max 3, collapsible) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvItemPesanan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:nestedScrollingEnabled="false"
        android:overScrollMode="never" />

    <!-- Tombol Lihat Semua Item -->
    <TextView
        android:id="@+id/btnLihatSemuaItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="▼  Lihat semua pesanan"
        android:textSize="12sp"
        android:textColor="@color/primary_red"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp" />

    <!-- Footer: Jarak, Durasi, Ongkir -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jarak"
                android:textSize="11sp"
                android:textColor="@color/text_sub" />

            <TextView
                android:id="@+id/tvJarak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="800 m"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Durasi"
                android:textSize="11sp"
                android:textColor="@color/text_sub" />

            <TextView
                android:id="@+id/tvDurasi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15 menit"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ongkir"
                android:textSize="11sp"
                android:textColor="@color/text_sub" />

            <TextView
                android:id="@+id/tvOngkir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp.15.000"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary_red"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Tombol Selesaikan (untuk status sedang diantar) -->
    <Button
        android:id="@+id/btnSelesaikan"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="12dp"
        android:text="Selesaikan Pesanan"
        android:textSize="13sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/primary_red"
        android:visibility="gone" />

</LinearLayout>