<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- TOP APP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/telkom_red"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:tint="@color/white"
            android:padding="2dp" />

        <!-- Foto + Nama — 4dp dari back, seperti detail pesanan -->
        <ImageView
            android:id="@+id/ivAvatarChat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_person"
            android:background="@drawable/bg_rounded_gray"
            android:scaleType="centerCrop"
            android:layout_marginStart="4dp" />

        <TextView
            android:id="@+id/tvNamaChatHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nama Pembeli"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <ImageView
            android:id="@+id/btnVoipCall"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_phone"
            android:tint="@color/white"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

    <!-- DAFTAR PESAN — stackFromEnd: pesan terbaru di bawah seperti WA -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

    <!-- PANEL INPUT CHAT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="8dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE" />

        <!-- Quick Reply Pilihan (Shopee-style) -->
        <HorizontalScrollView
            android:id="@+id/scrollQuickReply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="8dp"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/layoutQuickReply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/chipPesananSesuai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Pesanan sudah sesuai"
                    android:textSize="12sp"
                    android:textColor="@color/telkom_red"
                    android:background="@drawable/bg_chip_outline_red"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chipTitikSesuai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Titik pengantaran sesuai"
                    android:textSize="12sp"
                    android:textColor="@color/telkom_red"
                    android:background="@drawable/bg_chip_outline_red"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/chipBeliLagi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛒 Ada barang lain yang mau dibeli?"
                    android:textSize="12sp"
                    android:textColor="@color/telkom_red"
                    android:background="@drawable/bg_chip_outline_red"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Preview media -->
        <LinearLayout
            android:id="@+id/layoutMediaPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:background="#FFF5F5"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivMediaPreview"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:scaleType="centerCrop"
                android:background="#FFE0E0" />

            <TextView
                android:id="@+id/tvMediaLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="1 file dipilih"
                android:textSize="13sp"
                android:textColor="#424242" />

            <ImageView
                android:id="@+id/btnBatalMedia"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="#B00000"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="2dp" />
        </LinearLayout>

        <!-- Baris input teks + tombol -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp">

            <!-- Kamera GABUNG foto+video. Hide saat mengetik -->
            <ImageView
                android:id="@+id/btnKamera"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_photo_camera"
                android:tint="@color/telkom_red"
                android:padding="4dp"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="visible" />


            <!-- EditText pesan -->
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPesan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Tulis pesan..."
                android:textSize="14sp"
                android:textColor="#212121"
                android:background="@drawable/bg_input_chat"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:maxLines="4"
                android:inputType="textMultiLine|textCapSentences"
                android:imeOptions="actionNone" />

            <!-- Tombol Kirim -->
            <ImageView
                android:id="@+id/btnKirimPesan"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_send"
                android:tint="@color/white"
                android:background="@drawable/bg_circle_red"
                android:padding="10dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>