<?xml version="1.0" encoding="utf-8"?>
<!-- Bubble chat CUSTOMER (kiri, abu) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingVertical="4dp"
    android:paddingHorizontal="12dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="start"
        android:maxWidth="260dp">

        <!-- Bubble teks -->
        <TextView
            android:id="@+id/tvIsiPesan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pesan"
            android:textSize="14sp"
            android:textColor="#212121"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:background="@drawable/bg_bubble_custome"
            android:visibility="visible" />

        <!-- Bubble media (gambar/video) -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ivMediaPesan"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_bubble_custome"
                android:visibility="gone" />

            <!-- Badge VIDEO -->
            <TextView
                android:id="@+id/tvBadgeVideo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="▶ Video"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="#99000000"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Waktu -->
        <TextView
            android:id="@+id/tvWaktuPesan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:text="00:00"
            android:textSize="10sp"
            android:textColor="#9E9E9E"
            android:layout_marginTop="2dp"
            android:layout_marginStart="2dp" />
    </LinearLayout>
</LinearLayout>